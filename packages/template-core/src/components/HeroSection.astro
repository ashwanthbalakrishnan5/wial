---
import GrowthLine from "./GrowthLine.astro";

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  imageUrl?: string;
  chapterName: string;
}

const { title, subtitle, description, ctaText, ctaLink, imageUrl, chapterName } = Astro.props;
---

<section class="relative bg-brand-primary-light overflow-hidden" aria-label="Hero">
  <GrowthLine className="bottom-0 left-0 w-full h-16 text-brand-primary" />
  <div class="relative mx-auto max-w-[1200px] px-4 sm:px-6 py-16 md:py-24 z-10">
    <div class={`flex flex-col-reverse items-center gap-10 md:gap-16 ${imageUrl ? "md:flex-row" : ""}`}>
      {/* Text content */}
      <div class={`${imageUrl ? "flex-1 text-center md:text-left" : "w-full max-w-2xl mx-auto text-center"} stagger-fade-in`}>
        <h1 class="text-4xl md:text-5xl font-bold font-heading tracking-tight mb-4 opacity-0 animation-delay-100" style="color:var(--color-brand-primary)">
          {title}
        </h1>
        {subtitle && (
          <p class="text-xl md:text-2xl font-heading font-medium text-text-secondary mb-4 opacity-0 animation-delay-200">
            {subtitle}
          </p>
        )}
        {description && (
          <p class="text-lg text-text-secondary leading-relaxed mb-8 max-w-lg mx-auto md:mx-0 opacity-0 animation-delay-300">
            {description}
          </p>
        )}
        {ctaText && ctaLink && (
          <a
            href={ctaLink}
            class="inline-block px-8 py-3.5 text-base font-semibold rounded-full bg-brand-accent text-warm-charcoal hover:opacity-90 transition-opacity shadow-md opacity-0 animation-delay-400"
          >
            {ctaText}
          </a>
        )}
        <p class={`mt-6 text-xs text-text-muted flex items-center justify-center gap-1.5 opacity-0 animation-delay-500 ${imageUrl ? "md:justify-start" : ""}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          Part of the WIAL Global Network &mdash; 20+ chapters worldwide
        </p>
      </div>

      {/* Image */}
      {imageUrl && (
        <div class="flex-1 max-w-md md:max-w-none opacity-0 animate-fade-in-right">
          <img
            src={imageUrl}
            alt={`${chapterName} Action Learning`}
            class="w-full rounded-2xl shadow-lg object-cover aspect-[4/3]"
            loading="eager"
            width="600"
            height="450"
          />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .stagger-fade-in > * {
    animation: fadeUp 0.6s ease-out forwards;
  }
  .animation-delay-100 { animation-delay: 100ms; }
  .animation-delay-200 { animation-delay: 180ms; }
  .animation-delay-300 { animation-delay: 260ms; }
  .animation-delay-400 { animation-delay: 340ms; }
  .animation-delay-500 { animation-delay: 420ms; }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .animate-fade-in-right {
    animation: fadeInRight 0.8s ease-out 0.3s forwards;
  }

  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
