---
import { getCertColor } from "../lib/utils";

interface Props {
  level: string;
  size?: "sm" | "md";
}

const { level, size = "sm" } = Astro.props;
const { css } = getCertColor(level);
---

<span
  class:list={[
    "inline-flex items-center font-medium rounded-full border-l-[1.5px]",
    css,
    size === "sm" ? "px-2.5 py-0.5 text-xs" : "px-3 py-1 text-sm",
  ]}
  style="border-left-color: currentColor;"
>
  {level}
</span>
