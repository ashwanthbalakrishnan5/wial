---
import type { Tables } from "@repo/types";
import type { ContentBlockMap } from "../lib/content";
import { getBlock } from "../lib/content";

interface Props {
  chapter: Tables<"chapters">;
  contentBlocks: ContentBlockMap;
  currentPath: string;
  locale: string;
  activeLanguages: string[];
}

const { chapter, contentBlocks, currentPath, locale, activeLanguages } = Astro.props;

const prefix = `/${locale}`;

const navItems = [
  { href: `${prefix}/`, label: getBlock(contentBlocks, "nav_home_label", "Home") },
  { href: `${prefix}/about`, label: getBlock(contentBlocks, "nav_about_label", "About") },
  { href: `${prefix}/action-learning`, label: getBlock(contentBlocks, "nav_action_learning_label", "Action Learning") },
  { href: `${prefix}/coaches`, label: getBlock(contentBlocks, "nav_coaches_label", "Coaches") },
  { href: `${prefix}/testimonials`, label: getBlock(contentBlocks, "nav_testimonials_label", "Testimonials") },
  { href: `${prefix}/events`, label: getBlock(contentBlocks, "nav_events_label", "Events") },
  { href: `${prefix}/resources`, label: getBlock(contentBlocks, "nav_resources_label", "Resources") },
  { href: `${prefix}/contact`, label: getBlock(contentBlocks, "nav_contact_label", "Contact") },
  { href: `${prefix}/join`, label: getBlock(contentBlocks, "nav_join_label", "Join") },
];

function isActive(href: string): boolean {
  const normalized = currentPath.replace(/\/$/, "") || "/";
  const hrefNorm = href.replace(/\/$/, "") || `${prefix}`;
  if (hrefNorm === prefix) return normalized === prefix || normalized === `${prefix}/`;
  return normalized.startsWith(hrefNorm);
}

const pathWithoutLocale = currentPath.replace(/^\/[a-z]{2}(\/|$)/, "/");

const LANGUAGE_NAMES: Record<string, string> = {
  en: "EN", es: "ES", fr: "FR", pt: "PT", de: "DE",
  yo: "YO", vi: "VI", ko: "KO", ja: "JA", zh: "ZH",
  ar: "AR", hi: "HI", sw: "SW", tl: "TL",
};
---

<header class="sticky top-0 z-30 bg-white/95 border-b border-border-subtle transition-all duration-250 ease-out backdrop-blur-md" id="main-header">
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href={`${prefix}/`} class="flex-shrink-0" aria-label={`${chapter.name} home`}>
      {chapter.brand_logo_url ? (
        <img
          src={chapter.brand_logo_url}
          alt={chapter.name}
          class="h-10 w-auto"
        />
      ) : (
        <span
          class="text-xl font-bold font-heading tracking-tight"
          style={`color:${chapter.brand_primary_color}`}
        >
          {chapter.name}
        </span>
      )}
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-2 py-2 text-sm font-medium transition-all duration-200 relative h-16 flex items-center whitespace-nowrap",
            isActive(item.href)
              ? "text-brand-primary"
              : "text-text-secondary hover:text-brand-primary",
          ]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
          {isActive(item.href) && (
            <span class="absolute bottom-0 left-0 right-0 h-[3px] bg-brand-accent rounded-t-full"></span>
          )}
        </a>
      ))}

      {/* Language Switcher */}
      {activeLanguages.length > 1 && (
        <div class="ml-4 flex items-center gap-1 border-l border-border-subtle pl-4 h-8">
          {activeLanguages.map((lang) => (
            <a
              href={`/${lang}${pathWithoutLocale}`}
              class:list={[
                "px-2 py-1 text-xs font-bold rounded transition-colors",
                lang === locale
                  ? "bg-brand-primary text-white shadow-sm"
                  : "text-text-secondary hover:text-brand-primary hover:bg-brand-primary-light",
              ]}
              aria-label={`Switch to ${lang}`}
              aria-current={lang === locale ? "true" : undefined}
            >
              {LANGUAGE_NAMES[lang] ?? lang.toUpperCase()}
            </a>
          ))}
        </div>
      )}
    </nav>

    <!-- Mobile Hamburger (Pure CSS) -->
    <div class="lg:hidden">
      <input type="checkbox" id="nav-toggle" class="sr-only" aria-hidden="true" />
      <label
        for="nav-toggle"
        class="hamburger-btn"
        aria-label="Toggle navigation"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </label>
      
      <div class="mobile-nav-overlay fixed inset-0 bg-black/20 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300"></div>
      
      <nav class="mobile-nav" aria-label="Mobile navigation">
        <div class="flex flex-col gap-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
        
        {/* Mobile Language Switcher */}
        {activeLanguages.length > 1 && (
          <div class="flex items-center gap-3 mt-auto pt-8 border-t border-border-subtle">
            {activeLanguages.map((lang) => (
              <a
                href={`/${lang}${pathWithoutLocale}`}
                class:list={[
                  "flex-1 text-center py-2.5 text-sm font-bold rounded-lg transition-colors border",
                  lang === locale
                    ? "bg-brand-primary text-white border-brand-primary shadow-sm"
                    : "text-text-secondary border-border-subtle hover:bg-surface-muted",
                ]}
              >
                {LANGUAGE_NAMES[lang] ?? lang.toUpperCase()}
              </a>
            ))}
          </div>
        )}
      </nav>
    </div>
  </div>
</header>

<style is:global>
  .hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    cursor: pointer;
    z-index: 60;
    position: relative;
    margin-right: -8px;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text-primary, #1f1d1a);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 85%;
    max-width: 320px;
    background: white;
    z-index: 50;
    display: flex;
    flex-direction: column;
    padding: 5rem 2rem 2rem;
    box-shadow: -4px 0 25px rgba(0, 0, 0, 0.1);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
  }

  #nav-toggle:checked ~ .mobile-nav {
    transform: translateX(0);
  }

  #nav-toggle:checked ~ .mobile-nav-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  #nav-toggle:checked ~ label span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #nav-toggle:checked ~ label span:nth-child(2) {
    opacity: 0;
    transform: translateX(10px);
  }
  #nav-toggle:checked ~ label span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .mobile-nav a {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-secondary, #6b6560);
    transition: all 0.2s;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    display: block;
    text-decoration: none;
  }

  .mobile-nav a:hover {
    color: var(--color-brand-primary, #1a7a8a);
    background-color: var(--color-brand-primary-light, rgba(26, 122, 138, 0.05));
    text-decoration: none;
  }

  .mobile-nav a[aria-current="page"] {
    color: var(--color-brand-primary, #1a7a8a);
    background-color: var(--color-brand-primary-light, rgba(26, 122, 138, 0.05));
    border-left: 3px solid var(--color-brand-accent, #d4a900);
    padding-left: calc(1rem - 3px);
  }
</style>

<script>
  let lastScrollY = window.scrollY;
  let ticking = false;

  function updateHeader() {
    const header = document.getElementById('main-header');
    if (!header) return;

    if (window.scrollY > 30) {
      if (window.scrollY < lastScrollY) {
        // Scrolling up
        header.style.transform = 'translateY(0)';
        header.style.background = 'white';
        header.style.boxShadow = '0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06)';
      } else {
        // Scrolling down
        header.style.transform = 'translateY(-100%)';
      }
    } else {
      // Top of page
      header.style.transform = 'translateY(0)';
      header.style.background = 'rgba(255, 255, 255, 0.95)';
      header.style.boxShadow = 'none';
    }
    
    lastScrollY = window.scrollY;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(updateHeader);
      ticking = true;
    }
  }, { passive: true });
</script>
