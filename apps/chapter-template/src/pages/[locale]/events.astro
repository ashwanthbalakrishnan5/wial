---
import BaseLayout from "@repo/template-core/layouts/BaseLayout.astro";
import { getChapterData } from "@repo/template-core/lib/data";
import { getBlock } from "@repo/template-core/lib/content";

export async function getStaticPaths() {
  const slug = import.meta.env.CHAPTER_SLUG;
  const { chapter } = await getChapterData(slug);
  return chapter.active_languages.map((lang: string) => ({
    params: { locale: lang },
  }));
}

const { locale } = Astro.params;
const slug = import.meta.env.CHAPTER_SLUG;
const { contentBlocks, events } = await getChapterData(slug, locale);

const title = getBlock(contentBlocks, "events_title", "Events");
const description = getBlock(contentBlocks, "events_description", "");

const now = new Date();
const upcomingEvents = events.filter(
  (e) => new Date(e.end_date ?? e.start_date) >= now
);
const pastEvents = events
  .filter((e) => new Date(e.end_date ?? e.start_date) < now)
  .slice(0, 12);

function formatEventDate(start: string, end: string | null): string {
  const s = new Date(start);
  const opts: Intl.DateTimeFormatOptions = { month: "short", day: "numeric", year: "numeric" };
  if (!end) return s.toLocaleDateString("en-US", opts);
  const e = new Date(end);
  if (s.toDateString() === e.toDateString()) return s.toLocaleDateString("en-US", opts);
  return `${s.toLocaleDateString("en-US", { month: "short", day: "numeric" })}–${e.toLocaleDateString("en-US", opts)}`;
}

function getMonthDay(dateStr: string): { month: string; day: string; year: string } {
  const d = new Date(dateStr);
  return {
    month: d.toLocaleDateString("en-US", { month: "short" }).toUpperCase(),
    day: String(d.getDate()),
    year: String(d.getFullYear()),
  };
}

function toICalDate(dateStr: string): string {
  return new Date(dateStr).toISOString().replace(/[-:]/g, "").replace(/\.\d+/, "");
}

function generateICS(evt: typeof events[0]): string {
  const start = toICalDate(evt.start_date);
  const end = evt.end_date ? toICalDate(evt.end_date) : toICalDate(new Date(new Date(evt.start_date).getTime() + 3600000).toISOString());
  const desc = evt.description ? evt.description.replace(/<[^>]+>/g, "").replace(/\n/g, "\\n") : "";
  const loc = evt.is_virtual ? (evt.virtual_link || "Virtual") : (evt.location || "");
  return [
    "BEGIN:VCALENDAR",
    "VERSION:2.0",
    "PRODID:-//WIAL//Events//EN",
    "BEGIN:VEVENT",
    `DTSTART:${start}`,
    `DTEND:${end}`,
    `SUMMARY:${evt.title}`,
    `DESCRIPTION:${desc}`,
    `LOCATION:${loc}`,
    `UID:${evt.id}@wial`,
    "END:VEVENT",
    "END:VCALENDAR",
  ].join("\r\n");
}

const typeColors: Record<string, string> = {
  certification: "var(--color-brand-primary)",
  workshop: "var(--color-brand-secondary)",
  meetup: "#3b82f6",
  webinar: "var(--color-brand-accent)",
};
---

<BaseLayout title="Events" locale={locale}>
  {/* Hero Banner */}
  <section class="bg-brand-primary-light py-16 md:py-20">
    <div class="mx-auto max-w-[1200px] px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold font-heading" style="color:var(--color-brand-primary)">
        {title}
      </h1>
      {description && (
        <p class="text-lg text-text-secondary mt-4 max-w-xl mx-auto">{description}</p>
      )}
    </div>
  </section>

  {/* Upcoming Events */}
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-[900px] px-4 sm:px-6">
      {upcomingEvents.length > 0 ? (
        <div class="relative">
          {/* Timeline line */}
          <div class="absolute left-[47px] top-0 bottom-0 w-px bg-border-subtle hidden md:block" aria-hidden="true"></div>

          <div class="space-y-6">
            {upcomingEvents.map((evt) => {
              const { month, day, year } = getMonthDay(evt.start_date);
              const daysUntil = Math.ceil((new Date(evt.start_date).getTime() - now.getTime()) / 86400000);
              const color = typeColors[evt.event_type] || "var(--color-brand-primary)";
              return (
                <div class="flex gap-6 items-start">
                  {/* Date block */}
                  <div class="hidden md:flex flex-col items-center w-[96px] flex-shrink-0 text-center" style={`color:${color}`}>
                    <span class="text-xs font-semibold uppercase tracking-wider">{month}</span>
                    <span class="text-3xl font-bold font-heading leading-none">{day}</span>
                    <span class="text-xs text-text-muted">{year}</span>
                  </div>

                  {/* Event card */}
                  <div class="flex-1 rounded-xl border border-border-subtle bg-white p-5 shadow-sm">
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                      {daysUntil <= 7 && daysUntil >= 0 && (
                        <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium" style="background:#fef3c7;color:#92400e;">
                          Coming up
                        </span>
                      )}
                      <span
                        class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium"
                        style={`background:${color}1a;color:${color};`}
                      >
                        {evt.event_type}
                      </span>
                      {/* Mobile date */}
                      <span class="text-sm text-text-muted md:hidden">
                        {formatEventDate(evt.start_date, evt.end_date)}
                      </span>
                    </div>

                    <h3 class="text-lg font-semibold font-heading">{evt.title}</h3>

                    <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm text-text-secondary">
                      <span class="inline-flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                        {formatEventDate(evt.start_date, evt.end_date)}
                      </span>
                      {evt.is_virtual ? (
                        <span class="inline-flex items-center gap-1">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>
                          Virtual
                        </span>
                      ) : evt.location ? (
                        <span class="inline-flex items-center gap-1">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                          {evt.location}
                        </span>
                      ) : null}
                    </div>

                    {evt.description && (
                      <p class="mt-3 text-sm text-text-secondary line-clamp-2" set:html={evt.description} />
                    )}

                    <div class="mt-4 flex items-center gap-2">
                      {evt.registration_link && (
                        <a
                          href={evt.registration_link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1 rounded-full px-4 py-2 text-sm font-medium text-white transition-colors"
                          style={`background-color:var(--color-brand-accent);`}
                        >
                          Register
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                        </a>
                      )}
                      <a
                        href={`data:text/calendar;charset=utf-8,${encodeURIComponent(generateICS(evt))}`}
                        download={`${evt.title.replace(/[^a-zA-Z0-9]/g, "-")}.ics`}
                        class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-border-subtle text-text-secondary hover:text-brand-primary hover:border-brand-primary transition-colors"
                        title="Add to calendar"
                        aria-label={`Download calendar event: ${evt.title}`}
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M12 14v4"/><path d="M10 16h4"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ) : (
        <div class="text-center py-16">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-text-muted mb-4"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          <h3 class="text-lg font-semibold font-heading mb-1">No upcoming events</h3>
          <p class="text-sm text-text-secondary">Check back soon for workshops, certifications, and meetups.</p>
        </div>
      )}

      {/* Past Events */}
      {pastEvents.length > 0 && (
        <details class="mt-12">
          <summary class="cursor-pointer text-sm font-medium text-text-secondary hover:text-brand-primary transition-colors">
            View Past Events ({pastEvents.length})
          </summary>
          <div class="mt-6 space-y-4">
            {pastEvents.map((evt) => (
              <div class="flex gap-4 items-start rounded-lg border border-border-subtle bg-white p-4 opacity-75">
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-muted text-text-muted">
                      Past
                    </span>
                    <span class="text-sm text-text-muted">
                      {formatEventDate(evt.start_date, evt.end_date)}
                    </span>
                  </div>
                  <h4 class="font-medium">{evt.title}</h4>
                  {evt.location && (
                    <p class="text-sm text-text-muted mt-1">{evt.location}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </details>
      )}
    </div>
  </section>
</BaseLayout>
