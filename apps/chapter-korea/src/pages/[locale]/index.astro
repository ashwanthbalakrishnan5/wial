---
import BaseLayout from "@repo/template-core/layouts/BaseLayout.astro";
import HeroSection from "@repo/template-core/components/HeroSection.astro";
import StatsStrip from "@repo/template-core/components/StatsStrip.astro";
import CoachCard from "@repo/template-core/components/CoachCard.astro";
import TestimonialCard from "@repo/template-core/components/TestimonialCard.astro";
import { getChapterData } from "@repo/template-core/lib/data";
import { getBlock } from "@repo/template-core/lib/content";

export async function getStaticPaths() {
  const slug = import.meta.env.CHAPTER_SLUG;
  const { chapter } = await getChapterData(slug);
  return chapter.active_languages.map((lang: string) => ({
    params: { locale: lang },
  }));
}

const { locale } = Astro.params;
const slug = import.meta.env.CHAPTER_SLUG;
const { chapter, contentBlocks, coaches, featuredCoaches, featuredTestimonials } =
  await getChapterData(slug, locale);

const heroTitle = getBlock(contentBlocks, "hero_title", `Welcome to ${chapter.name}`);
const heroSubtitle = getBlock(contentBlocks, "hero_subtitle", "");
const heroDescription = getBlock(contentBlocks, "hero_description", "");
const heroCtaText = getBlock(contentBlocks, "hero_cta_text", "Learn More");
const heroCtaLink = getBlock(contentBlocks, "hero_cta_link", `/${locale}/about`);
const heroImageUrl = getBlock(contentBlocks, "hero_image_url", "");

const aboutBody = getBlock(contentBlocks, "about_body", "");
const aboutImageUrl = getBlock(contentBlocks, "about_image_url", "");
const aboutTeaser = aboutBody.replace(/<[^>]+>/g, "").substring(0, 300).trim();

const stats = [
  { value: `${coaches.length}+`, label: "Certified Coaches" },
];
---

<BaseLayout title="Home" locale={locale}>
  {/* Hero */}
  <HeroSection
    title={heroTitle}
    subtitle={heroSubtitle}
    description={heroDescription}
    ctaText={heroCtaText}
    ctaLink={heroCtaLink}
    imageUrl={heroImageUrl}
    chapterName={chapter.name}
  />

  {/* Stats */}
  <StatsStrip stats={stats} />

  {/* Featured Coaches — Editorial Layout */}
  {featuredCoaches.length > 0 && (
    <section class="py-16 md:py-24 relative overflow-hidden" aria-labelledby="coaches-heading">
      {/* Subtle background decoration */}
      <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-[0.02]" style="background: var(--color-brand-primary); filter: blur(80px)"></div>

      <div class="mx-auto max-w-[1200px] px-4 sm:px-6">
        {/* Section header — editorial style with accent bar */}
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
          <div class="max-w-lg">
            <p class="overline text-brand-accent mb-2">Our Team</p>
            <h2 id="coaches-heading" class="text-3xl md:text-4xl font-bold font-heading">
              Meet Our Coaches
            </h2>
            <p class="text-text-secondary mt-3 leading-relaxed">
              {getBlock(contentBlocks, "coaches_description", "Our certified Action Learning coaches are ready to help you grow.")}
            </p>
          </div>
          <a
            href={`/${locale}/coaches`}
            class="inline-flex items-center gap-2 text-sm font-semibold text-brand-primary hover:text-brand-accent transition-colors whitespace-nowrap group"
          >
            View All Coaches
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        {/* Coach grid — 3 columns on desktop for editorial feel */}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {featuredCoaches.slice(0, 3).map((coach) => (
            <CoachCard coach={coach} locale={locale} />
          ))}
        </div>

        {/* Extra coaches as a compact row */}
        {featuredCoaches.length > 3 && (
          <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {featuredCoaches.slice(3).map((coach) => (
              <CoachCard coach={coach} locale={locale} />
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {/* Testimonials — Magazine pull-quote section */}
  {featuredTestimonials.length > 0 && (
    <section class="relative py-16 md:py-24 overflow-hidden" aria-labelledby="testimonials-heading">
      {/* Full-bleed warm background */}
      <div class="absolute inset-0" style="background: linear-gradient(180deg, var(--color-surface-muted) 0%, var(--color-warm-ivory) 100%)"></div>

      {/* Top wave */}
      <div class="absolute top-0 left-0 right-0">
        <svg viewBox="0 0 1440 40" preserveAspectRatio="none" class="w-full h-8" fill="var(--color-warm-ivory)">
          <path d="M0,0 L1440,0 L1440,20 C1080,40 360,10 0,30 Z"/>
        </svg>
      </div>

      <div class="relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="overline text-brand-accent mb-2">Voices</p>
          <h2 id="testimonials-heading" class="text-3xl md:text-4xl font-bold font-heading">
            What People Say
          </h2>
        </div>

        {/* Testimonials — masonry-ish layout */}
        {featuredTestimonials.length === 1 ? (
          <div class="max-w-2xl mx-auto">
            <TestimonialCard testimonial={featuredTestimonials[0]} featured={true} />
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto items-start">
            {featuredTestimonials.map((t, i) => (
              <TestimonialCard testimonial={t} featured={i === 0} />
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {/* About Teaser — Asymmetric editorial layout */}
  {(aboutTeaser || aboutImageUrl) && (
    <section class="py-16 md:py-24" aria-labelledby="about-teaser-heading">
      <div class="mx-auto max-w-[1200px] px-4 sm:px-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-center">
          {/* Image — takes more space, with accent treatment */}
          {aboutImageUrl && (
            <div class="md:col-span-7 order-2 md:order-1">
              <div class="relative">
                {/* Decorative accent frame */}
                <div class="absolute -inset-3 rounded-2xl" style="background: linear-gradient(135deg, var(--color-brand-primary-light), var(--color-brand-accent-light)); opacity: 0.5"></div>
                <img
                  src={aboutImageUrl}
                  alt={`About ${chapter.name}`}
                  class="relative w-full rounded-2xl object-cover aspect-[16/10]"
                  loading="lazy"
                  width="700"
                  height="438"
                />
              </div>
            </div>
          )}
          {/* Text content */}
          <div class={`order-1 md:order-2 ${aboutImageUrl ? "md:col-span-5" : "md:col-span-8 md:col-start-3"}`}>
            <p class="overline text-brand-accent mb-2">Our Story</p>
            <h2 id="about-teaser-heading" class="text-3xl md:text-4xl font-bold font-heading mb-4">
              About {chapter.name}
            </h2>
            {aboutTeaser && (
              <p class="text-text-secondary leading-relaxed mb-6">
                {aboutTeaser}{aboutTeaser.length >= 300 ? "..." : ""}
              </p>
            )}
            <a
              href={`/${locale}/about`}
              class="inline-flex items-center gap-2 text-sm font-semibold text-brand-primary hover:text-brand-accent transition-colors group"
            >
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* CTA Banner — warm gradient section */}
  <section class="relative py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-secondary))"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;)"></div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 text-center">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold font-heading text-white mb-4">
        Ready to Transform Through Action?
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        Join our global community of action learning practitioners and start your journey today.
      </p>
      <a
        href={`/${locale}/join`}
        class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-full bg-white shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200"
        style="color:var(--color-brand-primary)"
      >
        Get Started
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
